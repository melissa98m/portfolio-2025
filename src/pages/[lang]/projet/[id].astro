---
import { LOCALES, type Locale } from "@/i18n/config";
import { getI18n } from "@/i18n";
import { projectsData, getProjectById, PROJECT_DETAIL_KEYS } from "@/data/projects";
import TechTag from "@/components/TechTag.astro";
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";

export function getStaticPaths() {
  const paths: { params: { lang: Locale; id: string } }[] = [];
  for (const lang of LOCALES) {
    for (const project of projectsData) {
      if (project.hasDetailPage) {
        paths.push({ params: { lang, id: project.id } });
      }
    }
  }
  return paths;
}

const { lang, id } = Astro.params as { lang: Locale; id: string };
const project = getProjectById(id);

if (!project || !project.hasDetailPage) {
  return Astro.redirect(`/${lang}#projects`);
}

const { t, dict } = getI18n(lang);
const title = `${project.title} — ${dict.meta.title}`;
const description = t(`projects.descriptions.${id}`);
const url = Astro.url.pathname;
---

<Layout {title} {description} {lang} {url} ogImage={`/${project.imageName}.png`}>
  <Nav {lang} {t} />
  <main class="min-h-screen text-[var(--white)] pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-6">
      <a
        href={`/${lang}#projects`}
        class="inline-flex items-center gap-2 text-[var(--white-icon)] hover:text-[var(--sec)] transition mb-8"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M7.82843 10L13.1924 15.364L11.7782 16.7782L4 9L11.7782 1.22183L13.1924 2.63604L7.82843 8H20V10H7.82843Z" />
        </svg>
        {t("projects.detail.backToProjects")}
      </a>

      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-semibold mb-4">{project.title}</h1>
        <p class="text-lg text-[var(--white-icon)] max-w-2xl">
          {t(`projects.detail.${id}.intro`)}
        </p>
        <div class="flex flex-wrap gap-2.5 mt-6">
          {project.techs.map((tech) => (
            <TechTag tech={tech} size="md" />
          ))}
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          <a
            href={project.preview || project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--sec)] text-white font-medium hover:opacity-90 transition"
          >
            {t("projects.detail.visitSite")}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V6C3 5.44772 3.44772 5 4 5H10ZM21 3V11H19V6.413L11.2071 14.2071L9.79289 12.7929L17.585 5H13V3H21Z" />
            </svg>
          </a>
          {project.link.includes("github.com") && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-[var(--white-icon-tr)] text-[var(--white)] font-medium hover:bg-[var(--white-icon-tr)] transition"
            >
              {t("projects.github")}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
              </svg>
            </a>
          )}
        </div>
      </header>

      <div class="rounded-2xl overflow-hidden mb-12 shadow-xl">
        <img
          src={`/${project.imageName}.png`}
          alt={project.title}
          class="w-full h-64 md:h-80 object-cover"
          width={800}
          height={400}
        />
      </div>

      {PROJECT_DETAIL_KEYS[id] && (
        <div class="space-y-12">
          <section>
            <h2 class="text-2xl font-semibold mb-6 text-[var(--sec)]">
              {t(`projects.detail.${id}.features.title`)}
            </h2>
            <ul class="space-y-3 text-[var(--white-icon)]">
              {PROJECT_DETAIL_KEYS[id].features.map((key) => (
                <li class="flex gap-3">
                  <span class="text-[var(--sec)]">•</span>
                  {t(`projects.detail.${id}.features.${key}`)}
                </li>
              ))}
            </ul>
          </section>

          <section>
            <h2 class="text-2xl font-semibold mb-6 text-[var(--sec)]">
              {t(`projects.detail.${id}.techStack.title`)}
            </h2>
            <div class="space-y-4 text-[var(--white-icon)]">
              {PROJECT_DETAIL_KEYS[id].techStack.map((key) => {
                const labelPath = `projects.detail.${id}.techStack.${key}Label`;
                const label = t(labelPath);
                const value = t(`projects.detail.${id}.techStack.${key}`);
                const hasLabel = label !== labelPath;
                return (
                  <p>
                    {hasLabel ? (
                      <><strong class="text-white">{label} :</strong> {value}</>
                    ) : (
                      value
                    )}
                  </p>
                );
              })}
            </div>
          </section>
        </div>
      )}
    </div>
  </main>
  <Footer {lang} {t} />
</Layout>
