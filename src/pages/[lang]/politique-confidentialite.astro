---
import { LOCALES, type Locale } from "@/i18n/config";
import { getI18n } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav.astro";
import Footer from "@/components/footer.astro";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const { t } = getI18n(lang);

const metaTitle = t("politiqueConfidentialite.metaTitle");
const metaDesc = t("politiqueConfidentialite.metaDesc");
const url = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
---

<Layout title={metaTitle} description={metaDesc} {lang} {url} {t}>
  <Nav {lang} {t} />
  <main class="min-h-screen pt-24 pb-16 px-4">
    <article class="max-w-3xl mx-auto space-y-8">
      <header>
        <a href={`/${lang}`} class="inline-flex items-center gap-2 text-[var(--sec)] hover:text-violet-400 transition-colors mb-6 text-sm">
          ← {t("politiqueConfidentialite.backHome")}
        </a>
        <h1 class="text-4xl font-medium text-[var(--white)] mb-2">{t("politiqueConfidentialite.title")}</h1>
        <p class="text-sm text-[var(--white-icon)]">{t("politiqueConfidentialite.lastUpdate")}</p>
      </header>

      <div class="prose prose-invert space-y-8 text-[var(--white-icon)]">
        <p class="leading-relaxed">{t("politiqueConfidentialite.intro")}</p>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.controller.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.controller.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.collected.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.collected.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.purpose.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.purpose.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.legalBasis.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.legalBasis.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.retention.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.retention.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.rights.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.rights.content")}</p>
        </section>

        <section>
          <h2 class="text-xl font-medium text-[var(--white)] mb-3">{t("politiqueConfidentialite.security.title")}</h2>
          <p class="leading-relaxed">{t("politiqueConfidentialite.security.content")}</p>
        </section>
      </div>
    </article>
  </main>
  <Footer {lang} {t} />
</Layout>
