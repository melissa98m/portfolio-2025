---
const { lang = "fr", t } = Astro.props as {
  lang: "fr" | "en";
  t: (k: string) => string;
};
import "../styles/cookie-banner.css";
---

<!-- Bouton flottant cookies (en bas de page) -->
<button
  type="button"
  id="cookie-settings-btn"
  aria-label={t("cookieBanner.manageCookies")}
  title={t("cookieBanner.manageCookies")}
  class="fixed bottom-6 right-6 z-[9998] p-3 rounded-full bg-[var(--container)] border border-[var(--line)] text-[var(--white-icon)] hover:text-violet-400 hover:border-violet-400/50 transition-all duration-300 shadow-lg opacity-0 pointer-events-none"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 5c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm-2 4c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm5 0c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm-2 5c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1z"/>
  </svg>
</button>

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[9999] p-4 md:p-6 bg-[var(--container)] border-t border-[var(--line)] shadow-lg transform translate-y-full"
  role="dialog"
  aria-labelledby="cookie-banner-title"
  aria-describedby="cookie-banner-desc"
>
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col gap-4" data-view="main">
      <div>
        <h2 id="cookie-banner-title" class="text-lg font-medium text-[var(--white)] mb-1">
          {t("cookieBanner.title")}
        </h2>
        <p id="cookie-banner-desc" class="text-sm text-[var(--white-icon)]">
          {t("cookieBanner.description")}
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <button
          type="button"
          data-cookie-action="accept-all"
          class="px-4 py-2 rounded-lg bg-[var(--sec)] text-[var(--background)] font-medium hover:opacity-90 transition-opacity"
        >
          {t("cookieBanner.acceptAll")}
        </button>
        <button
          type="button"
          data-cookie-action="essential"
          class="px-4 py-2 rounded-lg border border-[var(--white-icon-tr)] text-[var(--white)] hover:bg-[var(--white-icon-tr)] transition-colors"
        >
          {t("cookieBanner.acceptEssential")}
        </button>
        <button
          type="button"
          data-cookie-action="customize"
          class="px-4 py-2 rounded-lg border border-[var(--white-icon-tr)] text-[var(--white-icon)] hover:text-[var(--white)] transition-colors"
        >
          {t("cookieBanner.customize")}
        </button>
      </div>
    </div>

    <!-- Vue personnalisation (masquée par défaut) -->
    <div class="hidden flex-col gap-4" data-view="customize">
      <h2 class="text-lg font-medium text-[var(--white)]">{t("cookieBanner.customizeTitle")}</h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3 p-3 rounded-lg bg-[var(--background)]">
          <input type="checkbox" id="cookie-essential" checked disabled class="mt-1" />
          <label for="cookie-essential" class="text-sm text-[var(--white-icon)]">
            <span class="font-medium text-[var(--white)] block">{t("cookieBanner.essentialLabel")}</span>
            {t("cookieBanner.essentialDesc")}
          </label>
        </div>
        <div class="flex items-start gap-3 p-3 rounded-lg bg-[var(--background)]">
          <input type="checkbox" id="cookie-analytics" class="mt-1" />
          <label for="cookie-analytics" class="text-sm text-[var(--white-icon)]">
            <span class="font-medium text-[var(--white)] block">{t("cookieBanner.analyticsLabel")}</span>
            {t("cookieBanner.analyticsDesc")}
          </label>
        </div>
      </div>
      <div class="flex gap-3">
        <button
          type="button"
          data-cookie-action="save"
          class="px-4 py-2 rounded-lg bg-[var(--sec)] text-[var(--background)] font-medium hover:opacity-90 transition-opacity"
        >
          {t("cookieBanner.save")}
        </button>
        <button
          type="button"
          data-cookie-action="back"
          class="px-4 py-2 rounded-lg border border-[var(--white-icon-tr)] text-[var(--white-icon)] hover:text-[var(--white)] transition-colors"
        >
          {t("cookieBanner.close")}
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ lang }}>
  const COOKIE_CONSENT_KEY = "portfolio-cookie-consent";

  function getConsent() {
    try {
      const raw = localStorage.getItem(COOKIE_CONSENT_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function setConsent(analytics) {
    const data = { essential: true, analytics: !!analytics, timestamp: Date.now() };
    localStorage.setItem(COOKIE_CONSENT_KEY, JSON.stringify(data));
  }

  function hideBanner() {
    const banner = document.getElementById("cookie-banner");
    const btn = document.getElementById("cookie-settings-btn");
    if (banner) banner.classList.add("translate-y-full");
    if (btn) btn.classList.remove("opacity-0", "pointer-events-none");
  }

  function showBanner() {
    const banner = document.getElementById("cookie-banner");
    const btn = document.getElementById("cookie-settings-btn");
    if (banner) banner.classList.remove("translate-y-full");
    if (btn) btn.classList.add("opacity-0", "pointer-events-none");
  }

  function setupListeners() {
    const mainView = document.querySelector('[data-view="main"]');
    const customizeView = document.querySelector('[data-view="customize"]');

    function handleAction(action) {
      if (action === "accept-all") {
        setConsent(true);
        hideBanner();
      } else if (action === "essential") {
        setConsent(false);
        hideBanner();
      } else if (action === "customize") {
        mainView?.classList.add("hidden");
        customizeView?.classList.remove("hidden");
        customizeView?.classList.add("flex");
      } else if (action === "back") {
        mainView?.classList.remove("hidden");
        customizeView?.classList.add("hidden");
        customizeView?.classList.remove("flex");
      } else if (action === "save") {
        const analytics = document.getElementById("cookie-analytics")?.checked ?? false;
        setConsent(analytics);
        hideBanner();
      }
    }

    document.querySelectorAll("[data-cookie-action]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget;
        if (!target || !(target instanceof Element)) return;
        const action = target.getAttribute("data-cookie-action");
        if (action) handleAction(action);
      });
    });

    const cookieBtn = document.getElementById("cookie-settings-btn");
    if (cookieBtn) {
      cookieBtn.addEventListener("click", () => {
        if (typeof window.openCookiePreferences === "function") {
          window.openCookiePreferences();
        }
      });
    }
  }

  function initBanner() {
    const consent = getConsent();
    if (consent) {
      hideBanner(); // banner cachée, bouton visible
      if (consent.analytics && typeof window !== "undefined" && window.enableAnalytics) {
        window.enableAnalytics();
      }
    } else {
      showBanner(); // bannière visible, bouton masqué
    }
    setupListeners();
  }

  document.addEventListener("DOMContentLoaded", initBanner);

  // Réouvrir depuis "Gérer les cookies" dans le footer
  window.openCookiePreferences = function () {
    const banner = document.getElementById("cookie-banner");
    const mainView = document.querySelector('[data-view="main"]');
    const customizeView = document.querySelector('[data-view="customize"]');
    if (banner && customizeView) {
      showBanner();
      mainView?.classList.add("hidden");
      customizeView?.classList.remove("hidden");
      customizeView?.classList.add("flex");
      const analyticsCheck = document.getElementById("cookie-analytics");
      if (analyticsCheck) {
        const consent = getConsent();
        analyticsCheck.checked = consent?.analytics ?? false;
      }
    }
  };
</script>
