---
import "../styles/custom-cursor.css";
---
<div id="cursor" class="custom-cursor cursor-wrap">
  <div class="outer"></div>
  <div class="inner"></div>
</div>

<script is:inline>
  (function () {
    const initCustomCursor = () => {
      // Don’t run on touch / coarse pointers
      const mq = window.matchMedia("(hover: none), (pointer: coarse)");
      if (mq.matches) return;

      const root = document.documentElement;
      const wrap = document.getElementById('cursor');
      if (!(wrap instanceof HTMLElement)) return;

      const outer = wrap.querySelector('.outer');
      if (!(outer instanceof HTMLElement)) return;

      // selectors considered “clickable”
      const CLICKABLE = [
        'a','button','summary',
        '[role="button"]','[role="link"]',
        'input:not([type="hidden"])','textarea','select',
        '.cursor-pointer','[data-clickable]','[onclick]','[tabindex="0"]'
      ].join(',');

      /** @param {Element|null} el */
      const isClickable = (el) => !!(el && el.closest && el.closest(CLICKABLE));

      root.classList.add('custom-cursor-enabled');

      let shown = false;
      const pos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
      const tgt = { x: pos.x, y: pos.y };

      const reveal = () => {
        if (!shown) {
          wrap.style.display = 'block';
          shown = true;
        }
      };

      // Update position (used by move + pointerdown for focus restore)
      const updatePosition = (e) => {
        tgt.x = e.clientX;
        tgt.y = e.clientY;
        reveal();
        const el = document.elementFromPoint(tgt.x, tgt.y);
        wrap.classList.toggle('is-clickable', isClickable(el));
      };

      // Fallback show if no movement yet
      const showFallback = window.setTimeout(reveal, 120);

      window.addEventListener('pointermove', (e) => updatePosition(e), { passive: true });
      window.addEventListener('mousemove', (e) => updatePosition(e), { passive: true }); // fallback
      // Mise à jour position au clic → corrige le curseur figé au retour d'onglet
      document.addEventListener('pointerdown', (e) => updatePosition(e), { passive: true });

      // smooth tracking with inertia
      const speed = 0.18;
      const tick = () => {
        pos.x += (tgt.x - pos.x) * speed;
        pos.y += (tgt.y - pos.y) * speed;
        wrap.style.transform = `translate(${pos.x - 17}px, ${pos.y - 17}px)`; // 34 / 2
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      // Click feedback
      window.addEventListener('mousedown', () => { outer.style.transform = 'scale(0.95)'; });
      window.addEventListener('mouseup', () => { outer.style.transform = ''; });

      // Hide/Show sur perte de focus ou onglet caché
      const hide = () => { wrap.style.display = 'none'; };
      const show = () => { if (shown) wrap.style.display = 'block'; };

      window.addEventListener('blur', hide);
      window.addEventListener('focus', show);
      // visibilitychange gère mieux le retour d'onglet (plus fiable que focus)
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') hide();
        else show();
      });

      // Cleanup on hot reload (dev)
      window.addEventListener('astro:after-swap', () => {
        window.clearTimeout(showFallback);
      });
    };

    if (typeof window !== 'undefined') {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCustomCursor, { once: true });
      } else {
        initCustomCursor();
      }
    }
  })();
</script>
