---
<style>
  :root {
    --cursor-base: var(--sec);
    --cursor-active: #8151f0;
  }
  @supports (color: color-mix(in oklab, white 50%, black)) {
    :root { --cursor-active: color-mix(in oklab, var(--sec) 65%, black); }
  }

  /* hides the custom cursor on touch screens */
  @media (hover: none), (pointer: coarse) {
    .custom-cursor { display: none !important; }
  }

  /* custom cursor should never intercept clicks */
  .custom-cursor, .custom-cursor * { pointer-events: none; }

  .cursor-wrap {
    position: fixed; left: 0; top: 0;
    z-index: 9999;
    user-select: none;
    display: none;
    will-change: transform;
  }

  .outer {
    width: 34px; height: 34px;
    border-radius: 9999px;
    border: 2px solid var(--cursor-base);
    transition:
      border-color 160ms ease,
      border-width 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease,
      opacity 160ms ease;
    opacity: 0.98;
    box-shadow:
      0 0 18px rgba(164,118,255,0.35),
      0 0 2px rgba(0,0,0,0.25) inset;
    background-color: transparent;
  }

  .inner {
    position: absolute; left: 50%; top: 50%;
    width: 6px; height: 6px;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    background: var(--cursor-base);
    transition:
      background-color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease,
      opacity 160ms ease;
    box-shadow: 0 0 10px rgba(164,118,255,0.55);
  }

  /* pulsing halo for clickable state    */
  @keyframes glowPulse {
    0%   { box-shadow: 0 0 0 0 rgba(122,79,224,0.45), 0 0 22px rgba(122,79,224,0.65); }
    70%  { box-shadow: 0 0 0 12px rgba(122,79,224,0.00), 0 0 26px rgba(122,79,224,0.75); }
    100% { box-shadow: 0 0 0 0 rgba(122,79,224,0.00), 0 0 22px rgba(122,79,224,0.65); }
  }

  /* CLICK -> same shape, much stronger contrast */
  .is-clickable .outer {
    border-color: var(--cursor-active);
    border-width: 3px;
    transform: scale(1.25);
    /* light tint on the inside to fill the ring  */
    background-color: color-mix(in oklab, var(--cursor-active) 18%, transparent);
    box-shadow:
      0 0 0 0 rgba(122,79,224,0.45),
      0 0 28px rgba(122,79,224,0.85);
    animation: glowPulse 1200ms ease-out infinite;
  }

  .is-clickable .inner {
    background: var(--cursor-active);
    transform: translate(-50%, -50%) scale(1.6);
    box-shadow: 0 0 16px rgba(122,79,224,0.85);
  }

  @media (prefers-reduced-motion: reduce) {
    .outer, .inner { transition: none; animation: none !important; }
    .is-clickable .outer { transform: scale(1.15); }
    .is-clickable .inner { transform: translate(-50%, -50%) scale(1.35); }
  }
</style>

<div id="cursor" class="custom-cursor cursor-wrap">
  <div class="outer"></div>
  <div class="inner"></div>
</div>

<script is:inline>
  (function () {
    const initCustomCursor = () => {
      // Don’t run on touch / coarse pointers
      const mq = window.matchMedia("(hover: none), (pointer: coarse)");
      if (mq.matches) return;

      const root = document.documentElement;
      const wrap = document.getElementById('cursor');
      if (!(wrap instanceof HTMLElement)) return;

      const outer = wrap.querySelector('.outer');
      if (!(outer instanceof HTMLElement)) return;

      // selectors considered “clickable”
      const CLICKABLE = [
        'a','button','summary',
        '[role="button"]','[role="link"]',
        'input:not([type="hidden"])','textarea','select',
        '.cursor-pointer','[data-clickable]','[onclick]','[tabindex="0"]'
      ].join(',');

      /** @param {Element|null} el */
      const isClickable = (el) => !!(el && el.closest && el.closest(CLICKABLE));

      root.classList.add('custom-cursor-enabled');

      let shown = false;
      const pos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
      const tgt = { x: pos.x, y: pos.y };

      const reveal = () => {
        if (!shown) {
          wrap.style.display = 'block';
          shown = true;
        }
      };

      // Update position (used by move + pointerdown for focus restore)
      const updatePosition = (e) => {
        tgt.x = e.clientX;
        tgt.y = e.clientY;
        reveal();
        const el = document.elementFromPoint(tgt.x, tgt.y);
        wrap.classList.toggle('is-clickable', isClickable(el));
      };

      // Fallback show if no movement yet
      const showFallback = window.setTimeout(reveal, 120);

      window.addEventListener('pointermove', (e) => updatePosition(e), { passive: true });
      window.addEventListener('mousemove', (e) => updatePosition(e), { passive: true }); // fallback
      // Mise à jour position au clic → corrige le curseur figé au retour d'onglet
      document.addEventListener('pointerdown', (e) => updatePosition(e), { passive: true });

      // smooth tracking with inertia
      const speed = 0.18;
      const tick = () => {
        pos.x += (tgt.x - pos.x) * speed;
        pos.y += (tgt.y - pos.y) * speed;
        wrap.style.transform = `translate(${pos.x - 17}px, ${pos.y - 17}px)`; // 34 / 2
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      // Click feedback
      window.addEventListener('mousedown', () => { outer.style.transform = 'scale(0.95)'; });
      window.addEventListener('mouseup', () => { outer.style.transform = ''; });

      // Hide/Show sur perte de focus ou onglet caché
      const hide = () => { wrap.style.display = 'none'; };
      const show = () => { if (shown) wrap.style.display = 'block'; };

      window.addEventListener('blur', hide);
      window.addEventListener('focus', show);
      // visibilitychange gère mieux le retour d'onglet (plus fiable que focus)
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') hide();
        else show();
      });

      // Cleanup on hot reload (dev)
      window.addEventListener('astro:after-swap', () => {
        window.clearTimeout(showFallback);
      });
    };

    if (typeof window !== 'undefined') {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCustomCursor, { once: true });
      } else {
        initCustomCursor();
      }
    }
  })();
</script>
