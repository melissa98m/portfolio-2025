---
const { lang: _lang = "fr", t } = Astro.props as {
  lang?: "fr" | "en";
  t: (k: string) => string;
};
const cvPath = "/CV_MANGIONE_MELISSA.pdf";
---

<section id="contact" class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">
      {t("contact.kicker")}
    </h2>
    <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-6">
      {t("contact.title")}
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="text-[var(--white-icon)]">
        <p class="mb-4">
          {t("contact.blurb")}
        </p>
        <div class="flex items-center gap-2">
          <span>{t("contact.locationLabel")}</span>
          <span class="text-[var(--white)]">{t("contact.locationValue")}</span>
        </div>

        <!-- Button CV -->
        <div class="mt-4 flex items-center gap-3">
          <a
            href={cvPath}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--white-icon-tr)] bg-[#1414149c] text-violet-400 hover:text-violet-600 hover:bg-[var(--white-icon-tr)] transition duration-300 ease-in-out"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                d="M12 5C7 5 2.73 8.11 1 12c1.73 3.89 6 7 11 7s9.27-3.11 11-7c-1.73-3.89-6-7-11-7Zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10Zm0-2.5A2.5 2.5 0 1 0 12 9a2.5 2.5 0 0 0 0 5Z"
              ></path>
            </svg>
            <span class="text-sm md:text-base">{t("home.cv.view")}</span>
          </a>
          <a
            href={cvPath}
            download
            class="flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--white-icon-tr)] bg-[#1414149c]  text-violet-400 hover:text-violet-600 hover:bg-[var(--white-icon-tr)] transition duration-300 ease-in-out"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                d="M11 2h2v10.586l2.293-2.293 1.414 1.414L12 16.414l-4.707-4.707 1.414-1.414L11 12.586V2ZM5 18h14v2H5v-2Z"
              ></path>
            </svg>
            <span class="text-sm md:text-base">{t("home.cv.download")}</span>
          </a>
        </div>
      </div>

     <div>
  <form
    id="contact-form"
    action="/api/contact"
    method="POST"
    class="flex flex-col gap-4"
    novalidate
    data-name-required={t('contact.validation.nameRequired')}
  data-name-short={t('contact.validation.nameShort')}
  data-email-required={t('contact.validation.emailRequired')}
  data-email-invalid={t('contact.validation.emailInvalid')}
  data-message-required={t('contact.validation.messageRequired')}
  data-message-short={t('contact.validation.messageShort')}
  data-sent={t('contact.success')}
  data-failed={t('contact.error')}
  >
    <input type="text" name="company" class="hidden" tabindex="-1" autocomplete="off" />

    <div class="flex flex-col gap-1">
      <input
        type="text"
        name="from_name"
        placeholder={t("contact.name")}
        required
        minlength="2"
        class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)]"
        aria-invalid="false"
      />
      <p class="text-red-400 text-sm min-h-5" data-error="from_name"></p>
    </div>

    <div class="flex flex-col gap-1">
      <input
        type="email"
        name="reply_to"
        placeholder={t("contact.email")}
        required
        class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)]"
        aria-invalid="false"
      />
      <p class="text-red-400 text-sm min-h-5" data-error="reply_to"></p>
    </div>

    <div class="flex flex-col gap-1">
      <textarea
        name="message"
        placeholder={t("contact.message")}
        rows="6"
        required
        minlength="10"
        class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] resize-none"
        aria-invalid="false"
      ></textarea>
      <p class="text-red-400 text-sm min-h-5" data-error="message"></p>
    </div>

    <button
      id="contact-submit"
      type="submit"
      class="px-4 py-2 bg-[var(--white-icon-tr)] text-[var(--white)] rounded-lg opacity-60 transition-opacity border border-[var(--white-icon-tr)] hover:opacity-100 hover:bg-[var(--white-icon-tr)]"
    >
      {t("contact.send")}
    </button>
  </form>

  <div id="form-message" class="hidden justify-center items-center mt-4 text-[var(--white)] text-lg">
    ✅ {t("contact.success")}
  </div>
</div>


<style is:inline>
  .toast {
    position: fixed; left: 50%; bottom: 24px; transform: translateX(-50%);
    padding: 12px 16px; border-radius: 8px; background: rgba(20,20,20,.95);
    color: #fff; border: 1px solid rgba(255,255,255,.15); z-index: 9999;
    box-shadow: 0 6px 24px rgba(0,0,0,.35);
  }
  .toast-success { background: #1b4d2d; }
  .toast-error { background: #5b1b1b; }
</style>

<script type="module" is:inline>
  const form = document.getElementById("contact-form");
  const btn = document.getElementById("contact-submit");
  if (!form || !btn) {
    console.warn("[contact] form or button not found");
  } else {
    const errors = {
      from_name: document.querySelector('[data-error="from_name"]'),
      reply_to: document.querySelector('[data-error="reply_to"]'),
      message: document.querySelector('[data-error="message"]'),
    };

    const ds = form.dataset;
    const labels = {
      nameRequired: ds.nameRequired,
      nameShort: ds.nameShort,
      emailRequired: ds.emailRequired,
      emailInvalid: ds.emailInvalid,
      messageRequired: ds.messageRequired,
      messageShort: ds.messageShort,
      sent: ds.sent,
      failed: ds.failed,
    };

    function showToast(msg, type = "success") {
      const el = document.createElement("div");
      el.className = `toast ${type === "success" ? "toast-success" : "toast-error"}`;
      el.textContent = msg;
      document.body.appendChild(el);
      setTimeout(() => { el.remove(); }, 3500);
    }

    function setFieldError(name, msg) {
      if (errors[name]) errors[name].textContent = msg || "";
      const field = form.elements[name];
      if (field) field.setAttribute("aria-invalid", msg ? "true" : "false");
    }

    function validate() {
      let ok = true;

      // reset
      setFieldError("from_name", "");
      setFieldError("reply_to", "");
      setFieldError("message", "");

      const name = form.from_name.value.trim();
      const email = form.reply_to.value.trim();
      const message = form.message.value.trim();

      if (!name) { setFieldError("from_name", labels.nameRequired); ok = false; }
      else if (name.length < 2) { setFieldError("from_name", labels.nameShort); ok = false; }

      if (!email) { setFieldError("reply_to", labels.emailRequired); ok = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setFieldError("reply_to", labels.emailInvalid); ok = false; }

      if (!message) { setFieldError("message", labels.messageRequired); ok = false; }
      else if (message.length < 10) { setFieldError("message", labels.messageShort); ok = false; }

      return ok;
    }

    // live validation (blur)
    ["from_name", "reply_to", "message"].forEach((n) => {
      const el = form.elements[n];
      if (el) {
        el.addEventListener("blur", validate);
        el.addEventListener("input", () => setFieldError(n, "")); // clear on typing
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!validate()) return;

      const fd = new FormData(form);
      const qs = new URLSearchParams({
        from_name: String(fd.get("from_name") || ""),
        reply_to: String(fd.get("reply_to") || ""),
        message: String(fd.get("message") || ""),
        company: String(fd.get("company") || "")
      });

      btn.disabled = true; btn.style.opacity = "0.6";
      try {
        const res = await fetch(`${form.action}?${qs.toString()}`, {
          method: "POST",
          body: fd   // don't fix content-type: navigateur do this
        });

        if (res.ok) {
          form.reset();
          showToast(`✅ ${labels.sent}`, "success");
        } else {
          let data = {};
          try { data = await res.json(); } catch {}
          if (data && data.errors) {
            Object.entries(data.errors).forEach(([k, v]) => setFieldError(k, String(v)));
          }
          showToast(`❌ ${labels.failed}`, "error");
        }
      } catch (err) {
        showToast(`❌ ${labels.failed}`, "error");
      } finally {
        btn.disabled = false; btn.style.opacity = "";
      }
    });
  }
</script>
